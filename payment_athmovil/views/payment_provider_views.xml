<?xml version="1.0" encoding="utf-8"?>
<!-- Part of payment_athmovil. See LICENSE file for full copyright and licensing details. -->
<odoo>

    <record id="payment_provider_form_athmovil" model="ir.ui.view">
        <field name="name">payment.provider.form.athmovil</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='code']" position="after">

                <!-- Legal notice -->
                <div class="alert alert-warning" role="alert"
                     invisible="code != 'athmovil'">
                    <strong>Aviso Legal / Legal Notice:</strong>
                    You must accept
                    <a href="https://ath.business/terminos" target="_blank">ATH Business Terms</a>
                    before activating this provider.
                </div>

                <!-- Onboarding guide (Feature 2) -->
                <div class="alert alert-primary" role="alert"
                     invisible="code != 'athmovil'">
                    <strong>&#x1f680; Setup Guide / Guía de Configuración:</strong>
                    <ol class="mb-0 mt-2">
                        <li>Download <strong>ATH Business</strong> app
                            (<a href="https://apps.apple.com/app/ath-business/id1495442567" target="_blank">iOS</a> /
                             <a href="https://play.google.com/store/apps/details?id=com.evertec.athbusiness.android" target="_blank">Android</a>)
                        </li>
                        <li>Register your business and add a bank card</li>
                        <li>Go to <strong>Settings → Development</strong> in the ATH Business app</li>
                        <li>Copy your <strong>Public Token</strong> and <strong>Private Token</strong></li>
                        <li>Paste them below and click <strong>Test Connection</strong></li>
                        <li>Set Public Token to <code>dummy</code> for sandbox testing</li>
                    </ol>
                    <small class="text-muted">
                        Support: 787-773-5466 |
                        <a href="https://ath.business/botondepago" target="_blank">Technical support form</a>
                    </small>
                </div>

                <!-- Credential fields -->
                <group string="ATH Móvil Credentials"
                       invisible="code != 'athmovil'">
                    <field name="athmovil_public_token"
                           required="code == 'athmovil'"
                           invisible="code != 'athmovil'"
                           help="Found in ATH Business app → Settings → Development. Use 'dummy' for sandbox."/>
                    <field name="athmovil_private_token"
                           required="code == 'athmovil'"
                           invisible="code != 'athmovil'"
                           password="True"
                           help="Found in ATH Business app → Settings → Development. Keep secret."/>
                </group>

                <!-- Test Connection button (Feature 1) -->
                <div invisible="code != 'athmovil'" class="mt-2 mb-3">
                    <button name="action_athmovil_test_connection"
                            type="object"
                            string="🔗 Test Connection"
                            class="btn btn-secondary"
                            icon="fa-plug"
                            invisible="code != 'athmovil'"
                            help="Verify your ATH Móvil credentials are valid and the API is reachable."/>
                </div>

                <!-- Sandbox instructions -->
                <div class="alert alert-info" role="alert"
                     invisible="code != 'athmovil'">
                    <strong>Testing / Pruebas:</strong>
                    Set Public Token to <code>dummy</code> for sandbox mode.
                    You need a separate ATH Móvil Personal account on a different phone.
                </div>

            </xpath>
        </field>
    </record>

</odoo>
