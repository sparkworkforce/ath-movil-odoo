<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Email template sent to customer after successful ATH Móvil payment -->
    <record id="mail_template_athmovil_receipt" model="mail.template">
        <field name="name">ATH Móvil: Payment Receipt</field>
        <field name="model_id" ref="payment.model_payment_transaction"/>
        <field name="email_from">{{ (object.company_id.email or object.provider_id.company_id.email or '') }}</field>
        <field name="email_to">{{ object.partner_email }}</field>
        <field name="subject">ATH Móvil Payment Confirmed — {{ object.reference }}</field>
        <field name="body_html" type="html">
<div style="margin:0;padding:0;font-family:Arial,sans-serif;">
    <table width="100%" style="max-width:600px;margin:auto;border-collapse:collapse;">
        <tr>
            <td style="background:#00b140;padding:20px;text-align:center;color:white;">
                <h1 style="margin:0;font-size:24px;">✅ Payment Confirmed</h1>
            </td>
        </tr>
        <tr>
            <td style="padding:30px 20px;">
                <p>Hi <t t-out="object.partner_id.name or 'Customer'"/>,</p>
                <p>Your ATH Móvil payment has been successfully processed.</p>

                <table width="100%" style="border:1px solid #ddd;border-collapse:collapse;margin:20px 0;">
                    <tr style="background:#f8f9fa;">
                        <td style="padding:10px;border:1px solid #ddd;"><strong>Amount</strong></td>
                        <td style="padding:10px;border:1px solid #ddd;">$<t t-out="'%.2f' % object.amount"/> USD</td>
                    </tr>
                    <tr>
                        <td style="padding:10px;border:1px solid #ddd;"><strong>Reference</strong></td>
                        <td style="padding:10px;border:1px solid #ddd;"><t t-out="object.reference"/></td>
                    </tr>
                    <tr style="background:#f8f9fa;">
                        <td style="padding:10px;border:1px solid #ddd;"><strong>ATH ID</strong></td>
                        <td style="padding:10px;border:1px solid #ddd;"><t t-out="object.athmovil_ecommerce_id or 'N/A'"/></td>
                    </tr>
                    <tr>
                        <td style="padding:10px;border:1px solid #ddd;"><strong>Date</strong></td>
                        <td style="padding:10px;border:1px solid #ddd;"><t t-out="object.create_date"/></td>
                    </tr>
                </table>

                <p style="text-align:center;margin:30px 0;">
                    <a href="/my" style="background:#00b140;color:white;padding:12px 30px;text-decoration:none;border-radius:5px;display:inline-block;">
                        View Your Account
                    </a>
                </p>

                <p style="color:#666;font-size:12px;">
                    This payment was processed via ATH Móvil Business.<br/>
                    Support: 787-773-5466
                </p>
            </td>
        </tr>
    </table>
</div>
        </field>
    </record>

</odoo>
