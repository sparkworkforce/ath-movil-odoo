<odoo>

    <!-- ATH Móvil payment redirect form -->
    <template id="redirect_form" name="ATH Móvil Payment Form">

        <!--
            SECURITY (MED #8): The ATH Móvil CDN script cannot use SRI because
            it auto-updates with no stable hash. Instead we apply a Content
            Security Policy that restricts the script to only connect back to
            ATH Móvil's own domain and the current origin. A compromised CDN
            script cannot exfiltrate data to attacker-controlled servers.
        -->
        <meta http-equiv="Content-Security-Policy"
              content="connect-src 'self' https://payments.athmovil.com https://*.athmovil.com https://*.firebaseio.com https://*.googleapis.com; frame-src https://payments.athmovil.com https://*.athmovil.com;"/>

        <!-- ATH Móvil modal JS from CDN -->
        <script type="text/javascript"
                src="https://payments.athmovil.com/api/modal/js/athmovil_base.js"/>

        <div class="o_payment_athmovil_form">

            <!-- Inline info notice -->
            <div class="alert alert-info d-flex align-items-start o_athmovil_info_notice"
                 role="alert" data-testid="athmovil-info-notice">
                <span class="me-2" style="font-size:1.5rem;">&#x1f4f1;</span>
                <div>
                    <strong t-out="'ATH Móvil'"/>
                    — You'll need the ATH Móvil app to approve this payment.
                    The request expires in 10 minutes.
                    <br/>
                    <small class="text-muted">
                        Don't have it?
                        <a href="https://apps.apple.com/app/ath-movil/id658539297"
                           target="_blank" rel="noopener">App Store</a> ·
                        <a href="https://play.google.com/store/apps/details?id=com.evertec.athmovil.android"
                           target="_blank" rel="noopener">Google Play</a>
                    </small>
                </div>
            </div>

            <!-- Payment amount summary -->
            <div class="text-center mb-3" data-testid="athmovil-amount-display">
                <span class="text-muted">Total:</span>
                <strong class="fs-3" t-out="'$%.2f' % amount"/>
            </div>

            <!-- Legal notice (compact) -->
            <p class="text-muted small text-center">
                By paying you agree to
                <a href="https://ath.business/terminos" target="_blank">ATH Business Terms</a>.
            </p>

            <!-- Payment button -->
            <div class="o_athmovil_payment_container text-center mt-3">
                <button id="ATHMovil_Checkout_Button"
                        class="btn btn-primary btn-lg o_athmovil_pay_btn"
                        data-testid="athmovil-pay-button">
                    <span class="o_athmovil_btn_label">Pay with ATH Móvil</span>
                    <span class="o_athmovil_btn_loading d-none">
                        <span class="spinner-border spinner-border-sm me-1" role="status"/>
                        Opening ATH Móvil...
                    </span>
                </button>
            </div>

            <!-- Data container -->
            <div id="o_athmovil_data"
                 class="d-none"
                 data-testid="athmovil-data-container"
                 t-att-data-public-token="public_token"
                 t-att-data-amount="amount"
                 t-att-data-subtotal="subtotal"
                 t-att-data-tax="tax"
                 t-att-data-metadata1="metadata1"
                 t-att-data-metadata2="metadata2"
                 t-att-data-ecommerce-id="ecommerce_id"
                 t-att-data-items="items"
                 data-return-url="/payment/athmovil/return"
                 data-check-status-url="/payment/athmovil/check_status"
                 data-status-url="/payment/status"/>

            <!-- Loading state -->
            <div id="o_athmovil_loading"
                 class="text-center mt-4 d-none"
                 data-testid="athmovil-loading-spinner">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">Connecting to ATH Móvil...</p>
            </div>

        </div>

    </template>

</odoo>
