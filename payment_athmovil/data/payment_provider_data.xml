<odoo noupdate="1">

    <!-- =========================================================================
         Payment Provider: ATH Móvil
         Created in disabled state — the merchant must configure their credentials
         and manually enable the provider in Odoo Settings > Payment Providers.
         noupdate="1" prevents Odoo from overwriting admin changes on module update.
         ========================================================================= -->
    <record id="payment_provider_athmovil" model="payment.provider">
        <field name="name">ATH Móvil</field>
        <field name="code">athmovil</field>
        <field name="state">disabled</field>
        <field name="is_published">False</field>

        <!-- Restrict to Puerto Rico — ATH Móvil is only available in Puerto Rico -->
        <field name="supported_country_ids"
               eval="[(6, 0, [ref('base.pr')])]"/>

        <!-- Restrict to USD — ATH Móvil only supports USD transactions -->
        <field name="supported_currency_ids"
               eval="[(6, 0, [ref('base.USD')])]"/>
    </record>

    <!-- =========================================================================
         Scheduled Action: Expire Pending ATH Móvil Transactions
         Runs every 15 minutes to cancel transactions where the customer closed
         the browser without completing or cancelling the payment.
         Before cancelling, verifies real status via GET /findPayment to recover
         payments that were completed but whose webhook never arrived.
         ========================================================================= -->
    <record id="ir_cron_athmovil_expire_pending" model="ir.cron">
        <field name="name">ATH Móvil: Expire Pending Transactions</field>
        <field name="model_id" ref="payment.model_payment_provider"/>
        <field name="state">code</field>
        <field name="code">model._athmovil_expire_pending_transactions()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="doall">False</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>

</odoo>
